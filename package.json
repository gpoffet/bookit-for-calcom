{
	"name": "bookit-for-calcom",
	"version": "1.0.0",
	"description": "WordPress plugin integrating Cal.com booking widgets",
	"private": true,
	"scripts": {
		"start": "wp-scripts start --webpack-src-dir=blocks/cal-booking/src --output-path=blocks/cal-booking/build",
		"build": "wp-scripts build --webpack-src-dir=blocks/cal-booking/src --output-path=blocks/cal-booking/build",
		"lint:js": "wp-scripts lint-js blocks/cal-booking/src",
		"lint:css": "wp-scripts lint-style blocks/cal-booking/src"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.0.0"
	}
}
