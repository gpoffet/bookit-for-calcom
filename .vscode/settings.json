{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "[php]": {
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "editor.tabSize": 4
  },
  "intelephense.environment.phpVersion": "7.4",
  "intelephense.stubs": [
    "wordpress",
    "Core",
    "date",
    "json",
    "pcre",
    "standard"
  ],
  "php.validate.executablePath": "/usr/bin/php",
  "eslint.workingDirectories": ["blocks/cal-booking"],
  "files.associations": {
    "*.php": "php"
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/vendor": true,
    "blocks/cal-booking/build": false
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/vendor": true
  },
  "emmet.includeLanguages": {
    "php": "html"
  }
}
